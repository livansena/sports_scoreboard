<div class="min-h-screen bg-slate-950 text-white p-8">
  <div class="max-w-5xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <div>
        <p class="text-green-400 text-sm font-bold tracking-widest">
          SPORTS SCOREBOARD
        </p>

        <h1 class="text-4xl font-bold">
          Teams
        </h1>
      </div>

      <%= link_to "New Team",
          new_team_path,
          class: "bg-green-400 text-slate-950 px-5 py-3 rounded-lg font-bold hover:bg-green-300" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <% @teams.each do |team| %>
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
          <h2 class="text-2xl font-bold">
            <%= team.name %>
          </h2>

          <p class="text-slate-400 mt-2 mb-4">
            Registered team
          </p>

          <%= button_to "Delete",
              team_path(team),
              method: :delete,
              class: "bg-red-500 px-4 py-2 rounded-lg font-bold hover:bg-red-400",
              data: { turbo_confirm: "Delete this team?" } %>
        </div>
      <% end %>
    </div>
  </div>
</div>