<div class="min-h-screen bg-slate-950 text-white p-8">
  <div class="max-w-6xl mx-auto">

    <div class="flex justify-between items-center mb-8">
      <div>
        <p class="text-green-400 text-sm font-bold tracking-widest">
          SPORTS SCOREBOARD
        </p>

        <h1 class="text-4xl font-bold">
          Matches
        </h1>
      </div>

      <%= link_to "New Match", new_match_path,
        class: "bg-green-400 text-slate-950 px-5 py-3 rounded-lg font-bold hover:bg-green-300" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <% @matches.each do |match| %>

        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">

          <div class="flex items-center justify-between">

            <div class="text-center">
              <h2 class="text-2xl font-bold">
                <%= match.home_team.name %>
              </h2>
            </div>

            <div class="text-center">
              <p class="text-4xl font-bold text-green-400">
                <%= match.home_score %> x <%= match.away_score %>
              </p>
            </div>

            <div class="text-center">
              <h2 class="text-2xl font-bold">
                <%= match.away_team.name %>
              </h2>
            </div>

          </div>

        </div>

      <% end %>

    </div>

  </div>
</div>